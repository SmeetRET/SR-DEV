{% comment %} <script>
(function () {
 'use strict';

 // ── Helpers ──────────────────────────────────────────────
 function fmt(n) {
 return '$' + Number(n).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
 }
 function fmtPct(n) { return n.toFixed(1) + '%'; }
 function val(id) { return parseFloat(document.getElementById(id).value) || 0; }

 // ── TCO calculation ──────────────────────────────────────
 // In-warranty years → OOW replacement cost = $0
 // Out-of-warranty → OOW replacement cost = oow × cpu per year
 function calcTCO(units, cpu, lifespan, warranty, oow, shipping, sanitize, lost) {
 var total = units * cpu;
 var years = Math.ceil(lifespan);
 for (var y = 1; y <= years; y++) {
 var oowCost = (y <= warranty) ? 0 : oow * cpu;
 var lostCost = lost * cpu;
 total += oowCost + lostCost + shipping + (units * sanitize);
 }
 return total;
 }

 function getLineItems(units, cpu, lifespan, warranty, oow, shipping, sanitize, lost) {
 var yrs = Math.ceil(lifespan);
 var oowTotal = 0;
 for (var y = 1; y <= yrs; y++) { if (y > warranty) oowTotal += oow * cpu; }
 return [
 { label: 'Initial unit purchase', v: units * cpu },
 { label: 'Shipping (over lifespan)', v: shipping * yrs },
 { label: 'Sanitization (over lifespan)', v: units * sanitize * yrs },
 { label: 'Lost / stolen replacements', v: lost * cpu * yrs },
 { label: 'Out-of-warranty replacements', v: oowTotal },
 ];
 }

 // ── Model selector sync ───────────────────────────────────
 var modelSelect = document.getElementById('twt-model');
 var msrpDisplay = document.getElementById('twt-msrp-display');
 var warrantyDisp = document.getElementById('twt-warranty-display');
 var warrantyInput = document.getElementById('twt-warranty-input');
 var modelImg = document.getElementById('twt-model-img');
 var imgPlaceholder = document.getElementById('twt-img-placeholder');

 function syncModel() {
 var opt = modelSelect.options[modelSelect.selectedIndex];
 var msrp = parseFloat(opt.getAttribute('data-msrp')) || 0;
 var warranty = opt.getAttribute('data-warranty') || '2';
 var image = opt.getAttribute('data-image') || '';

 msrpDisplay.textContent = '$' + msrp.toFixed(2);
 warrantyDisp.textContent = warranty + ' year' + (warranty == '1' ? '' : 's');
 warrantyInput.value = warranty + ' year' + (warranty == '1' ? '' : 's');

 if (image) {
 modelImg.src = image;
 modelImg.style.display = 'block';
 imgPlaceholder.style.display = 'none';
 } else {
 modelImg.style.display = 'none';
 imgPlaceholder.style.display = 'block';
 }
 }
 modelSelect.addEventListener('change', syncModel);
 syncModel();

 // ── Mirror competitor → TWT readonly fields ───────────────
 var mirrors = [
 ['comp-units', 'twt-units'],
 ['comp-oow', 'twt-oow'],
 ['comp-sanitize', 'twt-sanitize'],
 ['comp-lost', 'twt-lost'],
 ];
 function syncMirrors() {
 mirrors.forEach(function (p) {
 var s = document.getElementById(p[0]);
 var d = document.getElementById(p[1]);
 if (s && d) d.value = s.value;
 });
 }
 mirrors.forEach(function (p) {
 var el = document.getElementById(p[0]);
 if (el) el.addEventListener('input', syncMirrors);
 });
 syncMirrors();

 // ── Stash pending results until Klaviyo form submits ──────
 var _pending = null;

 function computeResults() {
 var compUnits = val('comp-units');
 var compCpu = val('comp-cpu');
 var compLifespan = val('comp-lifespan');
 var compWarranty = val('comp-warranty');
 var compOow = val('comp-oow');
 var compShipping = val('comp-shipping');
 var compSanitize = val('comp-sanitize');
 var compLost = val('comp-lost');
 var opt = modelSelect.options[modelSelect.selectedIndex];
 var twtWarranty = parseInt(opt.getAttribute('data-warranty')) || 2;
 var twtCpu = val('twt-cpu');

 var compTCO = calcTCO(compUnits, compCpu, compLifespan, compWarranty, compOow, compShipping, compSanitize, compLost);
 var twtTCO = calcTCO(compUnits, twtCpu, 3.7, twtWarranty, compOow, 0, compSanitize, compLost);
 var savings = compTCO - twtTCO;
 var roi = twtTCO > 0 ? (savings / twtTCO) * 100 : 0;

 return {
 compTCO: compTCO,
 twtTCO: twtTCO,
 savings: savings,
 roi: roi,
 compLines: getLineItems(compUnits, compCpu, compLifespan, compWarranty, compOow, compShipping, compSanitize, compLost),
 twtLines: getLineItems(compUnits, twtCpu, 3.7, twtWarranty, compOow, 0, compSanitize, compLost),
 };
 }

 function renderResults(r) {
 document.getElementById('res-comp-tco').textContent = fmt(r.compTCO);
 document.getElementById('res-twt-tco').textContent = fmt(r.twtTCO);
 document.getElementById('res-savings').textContent = fmt(r.savings);
 document.getElementById('res-roi').textContent = fmtPct(r.roi);

 var tbody = document.getElementById('tco-breakdown-tbody');
 tbody.innerHTML = '';
 r.compLines.forEach(function (item, i) {
 var save = item.v - r.twtLines[i].v;
 var tr = document.createElement('tr');
 tr.innerHTML =
 '<td>' + item.label + '</td>' +
 '<td class="td-comp">' + fmt(item.v) + '</td>' +
 '<td class="td-twt">' + fmt(r.twtLines[i].v) + '</td>' +
 '<td class="td-save">' + (save >= 0 ? fmt(save) : '&minus;' + fmt(Math.abs(save))) + '</td>';
 tbody.appendChild(tr);
 });

 var totalRow = document.createElement('tr');
 totalRow.className = 'total-row';
 totalRow.innerHTML =
 '<td>3-Year Total</td>' +
 '<td class="td-comp">' + fmt(r.compTCO) + '</td>' +
 '<td class="td-twt">' + fmt(r.twtTCO) + '</td>' +
 '<td class="td-save">' + fmt(r.savings) + '</td>';
 tbody.appendChild(totalRow);

 var resultsEl = document.getElementById('tco-results');
 resultsEl.classList.add('active');
 setTimeout(function () {
 resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
 }, 200);
 }

 // ── Modal open / close ────────────────────────────────────
 var overlay = document.getElementById('tco-modal-overlay');
 var openBtn = document.getElementById('tco-open-modal');
 var closeBtn = document.getElementById('tco-modal-close');

 openBtn.addEventListener('click', function () {
 _pending = computeResults();
 overlay.classList.add('active');
 });
 closeBtn.addEventListener('click', function () { overlay.classList.remove('active'); });
 overlay.addEventListener('click', function (e) {
 if (e.target === overlay) overlay.classList.remove('active');
 });

 // ── Push results as Klaviyo profile properties ───────────
 // Called immediately after form submit so the Flow email
 // can reference real numbers via {{ person.tco_savings }} etc.
 //
 // Profile properties set on the customer:
 // tco_model — selected TWT model name
 // tco_competitor_tco — e.g. "$93,750.00"
 // tco_twt_tco — e.g. "$68,425.00"
 // tco_savings — e.g. "$25,325.00"
 // tco_roi — e.g. "37.0%"
 // tco_units — e.g. 5000
 // tco_comp_cpu — e.g. "$18.75"
 // tco_twt_cpu — e.g. "$13.75"
 // tco_comp_warranty — e.g. "1 year"
 // tco_twt_warranty — e.g. "2 years"
 // tco_submitted_at — ISO timestamp
 //
 // Use in Klaviyo Flow email template:
 // You saved {{ person.tco_savings }} over 3 years with {{ person.tco_model }}!
 // Competitor TCO: {{ person.tco_competitor_tco }}
 // TWT Audio TCO: {{ person.tco_twt_tco }}
 // ROI: {{ person.tco_roi }}

 function pushToKlaviyo(r) {
 if (!window._learnq) {
 console.warn('TCO: Klaviyo (_learnq) not available.');
 return;
 }

 var opt = modelSelect.options[modelSelect.selectedIndex];
 var modelName = opt.getAttribute('data-title') || opt.value;
 var twtWarranty = parseInt(opt.getAttribute('data-warranty')) || 2;
 var compWarranty = val('comp-warranty');

 // _learnq.push identify updates the already-identified profile
 // (Klaviyo identifies them from the form submission just before this runs)
 window._learnq.push(['identify', {
 // Results
 'tco_model': modelName,
 'tco_competitor_tco': fmt(r.compTCO),
 'tco_twt_tco': fmt(r.twtTCO),
 'tco_savings': fmt(r.savings),
 'tco_roi': fmtPct(r.roi),
 // Key inputs — useful for sales follow-up context
 'tco_units': val('comp-units'),
 'tco_comp_cpu': fmt(val('comp-cpu')),
 'tco_twt_cpu': fmt(val('twt-cpu')),
 'tco_comp_warranty': compWarranty + ' year' + (compWarranty == 1 ? '' : 's'),
 'tco_twt_warranty': twtWarranty + ' year' + (twtWarranty == 1 ? '' : 's'),
 'tco_submitted_at': new Date().toISOString(),
 }]);
 }

 // ── Klaviyo form submission listener ─────────────────────
 // Klaviyo fires window event 'klaviyoForms' with detail.type === 'submit'
 // on successful form submission. We:
 // 1. Push TCO results as profile properties (for the Flow email)
 // 2. Close the modal
 // 3. Render results on the page
 window.addEventListener('klaviyoForms', function (e) {
 if (e.detail && e.detail.type === 'submit') {
 if (_pending) {
 pushToKlaviyo(_pending); // ← push results to Klaviyo profile first
 overlay.classList.remove('active');
 renderResults(_pending);
 _pending = null;
 } else {
 overlay.classList.remove('active');
 }
 }
 });

})();
